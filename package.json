{
  "name": "claude-skill-lint",
  "version": "0.2.1",
  "description": "A CLI tool that validates Claude Code skill files for structural correctness",
  "type": "module",
  "bin": {
    "claude-skill-lint": "bin/cli.js",
    "skill-lint": "bin/cli.js"
  },
  "files": [
    "dist/",
    "bin/",
    "schemas/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test test/*.test.ts"
  },
  "keywords": [
    "claude",
    "skills",
    "linter",
    "validation",
    "claude-code",
    "plugin"
  ],
  "author": "Robin Cannon <robin@shinytoyrobots.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinytoyrobots/claude-skills-linter.git"
  },
  "dependencies": {
    "@stoplight/spectral-core": "^1.21.0",
    "@stoplight/spectral-functions": "^1.10.1",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "minimatch": "^10.2.4",
    "yaml": "^2.8.3",
    "yargs": "^17.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.0",
    "ajv": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
